#!/usr/bin/env python3

# scripts/resscan_batch
import argparse
import pandas as pd
import subprocess
import sys
import time
import io
import shlex
import multiprocessing
import shutil
from pathlib import Path
from collections import Counter

class Colors:
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'

def format_duration(seconds):
    if seconds < 60: return f"{seconds:.2f} seconds"
    m, s = divmod(seconds, 60)
    return f"{int(m)} minutes {int(s)} seconds"

def run_worker(task_info):
    """Standalone worker function for resscan execution."""
    sid, fqs, args_dict, pass_through_flags = task_info
    
    clean_sample_id = str(sid).strip().replace(" ", "_")
    output_subdir = Path(args_dict['output_dir']) / clean_sample_id
    output_subdir.mkdir(parents=True, exist_ok=True)
    
    output_prefix = output_subdir / f"{clean_sample_id}_results"
    
    # Constructing the command
    cmd = [
        "resscan",
        "-i", ",".join(fqs),
        "-o", str(output_prefix),
        "--card-db-dir", args_dict['card_db_dir'],
        "-t", str(args_dict['threads_per_sample'])
    ]
    cmd.extend(pass_through_flags)
    
    start_time_unix = time.time()
    
    try:
        # Redirecting to DEVNULL to avoid pipe-buffer deadlocks
        subprocess.run(
            cmd, 
            stdout=subprocess.DEVNULL, 
            stderr=subprocess.DEVNULL, 
            check=True
        )
        status = "SUCCESS"
    except Exception:
        status = "FAILED"
    
    return {
        "sample": sid,
        "status": status,
        "start_time": time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(start_time_unix)),
        "duration": format_duration(time.time() - start_time_unix),
        "command": " ".join(map(shlex.quote, cmd)),
        "files": fqs
    }

def main():
    # Use 'spawn' to prevent inconsistent stalls/deadlocks on Linux
    try:
        multiprocessing.set_start_method('spawn', force=True)
    except RuntimeError:
        pass

    total_start_time = time.monotonic()
    
    parser = argparse.ArgumentParser(description="resscan batch pipeline with real-time logging.")
    parser.add_argument("-s", "--samplesheet", required=True, help="Path to samplesheet CSV.")
    parser.add_argument("--card-db-dir", required=True, help="CARD database directory.")
    parser.add_argument("-o", "--output-dir", default="resscan_batch_results", help="Output directory.")
    parser.add_argument("--overwrite", action="store_true", help="Delete and recreate output directory.")
    parser.add_argument("-p", "--parallel-samples", type=int, default=1, help="Simultaneous samples.")
    parser.add_argument("-t", "--threads-per-sample", type=int, default=8, help="Threads per sample.")
    
    args, pass_through_flags = parser.parse_known_args()
    output_path = Path(args.output_dir)

    # 1. Output Directory Handling
    if output_path.exists():
        if args.overwrite:
            print(f"{Colors.WARNING}Overwriting: Removing existing directory '{args.output_dir}'...{Colors.ENDC}")
            try:
                shutil.rmtree(output_path)
                time.sleep(0.5) # Filesystem sync pause
            except Exception as e:
                print(f"{Colors.FAIL}Error removing directory: {e}{Colors.ENDC}")
                sys.exit(1)
        else:
            print(f"{Colors.FAIL}ERROR: Output directory '{args.output_dir}' already exists.{Colors.ENDC}")
            print(f"{Colors.WARNING}Use --overwrite to delete and recreate it.{Colors.ENDC}")
            sys.exit(1)
    
    output_path.mkdir(parents=True, exist_ok=True)

    # 2. Load and Validate Samplesheet
    try:
        with open(args.samplesheet, 'r') as f:
            lines = [line.strip() for line in f if line.strip()]
        if not lines: raise ValueError("Samplesheet is empty.")
        if lines[0].startswith('#'): lines[0] = lines[0].lstrip('#').strip()
        
        df = pd.read_csv(io.StringIO("\n".join(lines)), engine='python')
        if 'sample' not in df.columns:
            raise ValueError("Samplesheet must contain a 'sample' column.")
            
        fastq_cols = [c for c in df.columns if c != 'sample']
    except Exception as e:
        print(f"{Colors.FAIL}Samplesheet Error: {e}{Colors.ENDC}")
        sys.exit(1)

    # 3. Validation for Duplicates
    sample_ids = df['sample'].astype(str).str.strip()
    sample_counts = Counter(sample_ids)
    dup_samples = [s for s, count in sample_counts.items() if count > 1]
    
    all_fqs = []
    tasks = []
    for _, row in df.iterrows():
        sid = str(row['sample']).strip()
        fqs = [str(row[col]).strip() for col in fastq_cols if pd.notna(row[col]) and str(row[col]).strip()]
        if fqs:
            all_fqs.extend(fqs)
            tasks.append((sid, fqs, vars(args), pass_through_flags))

    fq_counts = Counter(all_fqs)
    dup_fqs = [f for f, count in fq_counts.items() if count > 1]

    if dup_samples or dup_fqs:
        print(f"{Colors.FAIL}{Colors.BOLD}--- Validation Failed ---{Colors.ENDC}")
        if dup_samples:
            print(f"{Colors.WARNING}Duplicate Sample IDs: {', '.join(dup_samples)}{Colors.ENDC}")
        if dup_fqs:
            print(f"{Colors.WARNING}Duplicate FASTQ files: {', '.join(dup_fqs)}{Colors.ENDC}")
        sys.exit(1)

    # 4. Execution and Real-Time Logging
    total_tasks = len(tasks)
    print(f"{Colors.BLUE}{Colors.BOLD}--- Processing {total_tasks} samples ---{Colors.ENDC}\n")
    
    master_log_path = output_path / "batch_run.log"
    
    # Initialise log file with header
    with open(master_log_path, "w") as log:
        log.write(f"RESSCAN BATCH LOG SUMMARY\n{'='*25}\n")
        log.write(f"Total Samples: {total_tasks}\n")
        log.write(f"Run Started:   {time.strftime('%Y-%m-%d %H:%M:%S')}\n\n")

    completed_count = 0
    with multiprocessing.Pool(processes=args.parallel_samples) as pool:
        for result in pool.imap_unordered(run_worker, tasks):
            completed_count += 1
            
            # Terminal output with progress counter
            status_color = Colors.GREEN if result["status"] == "SUCCESS" else Colors.FAIL
            progress_str = f"[{completed_count}/{total_tasks}]"
            print(f"{status_color}[{result['status']}]{Colors.ENDC} {result['sample']} {Colors.CYAN}{progress_str}{Colors.ENDC} ({result['duration']})")
            
            # Append to master log in real-time
            with open(master_log_path, "a") as log:
                log.write(f"SAMPLE:  {result['sample']}\n")
                log.write(f"STATUS:  {result['status']}\n")
                log.write(f"TIME:    {result['start_time']} ({result['duration']})\n")
                log.write(f"CMD:     {result['command']}\n")
                log.write(f"FILES:   {', '.join(result['files'])}\n")
                log.write("-" * 25 + "\n")
                log.flush()

    # Final summary
    total_duration = format_duration(time.monotonic() - total_start_time)
    print(f"\n{Colors.GREEN}{Colors.BOLD}Batch run complete!{Colors.ENDC}")
    print(f"{Colors.BLUE}Total Runtime: {total_duration}{Colors.ENDC}")
    print(f"{Colors.BLUE}Master Log:    {master_log_path}{Colors.ENDC}")

if __name__ == "__main__":
    main()