#!/usr/bin/env python3

# scripts/resscan_batch
import argparse
import pandas as pd
import subprocess
import sys
import time
import io
from pathlib import Path
from concurrent.futures import ProcessPoolExecutor

class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    GREY = '\033[90m'

def format_duration(seconds):
    """Formats a duration in seconds into a human-readable string."""
    if seconds < 60: return f"{seconds:.2f} seconds"
    m, s = divmod(seconds, 60)
    return f"{int(m)} minutes {int(s)} seconds"

def run_single_sample(sample_id, fastq_list, args, pass_through_flags):
    """Orchestrates a single resscan run with multiple inputs."""
    clean_sample_id = str(sample_id).strip().replace(" ", "_")
    output_subdir = Path(args.output_dir) / clean_sample_id
    output_subdir.mkdir(parents=True, exist_ok=True)
    
    input_str = ",".join(fastq_list)
    output_prefix = output_subdir / f"{clean_sample_id}_results"
    
    cmd = [
        "resscan",
        "-i", input_str,
        "-o", str(output_prefix),
        "--card-db-dir", args.card_db_dir,
        "-t", str(args.threads_per_sample)
    ]
    cmd.extend(pass_through_flags)
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return f"{Colors.GREEN}[SUCCESS]{Colors.ENDC} {sample_id}"
    except subprocess.CalledProcessError as e:
        return f"{Colors.FAIL}[FAILED]{Colors.ENDC} {sample_id}\n{Colors.GREY}{e.stderr}{Colors.ENDC}"

def main():
    start_time = time.monotonic()
    parser = argparse.ArgumentParser(
        description="resscan batch pipeline with path validation.",
        formatter_class=argparse.RawTextHelpFormatter
    )

    # I/O Arguments
    io_group = parser.add_argument_group('I/O Arguments')
    io_group.add_argument("-s", "--samplesheet", required=True, 
                          help="Path to CSV. Supports '#' in header and variable FASTQ columns.")
    io_group.add_argument("--card-db-dir", required=True, 
                          help="Directory containing the prepared CARD database files.")
    io_group.add_argument("-o", "--output-dir", default="resscan_batch_results", 
                          help="Parent directory for all sample outputs.")
    
    # Parallelism Arguments
    parallel_group = parser.add_argument_group('Parallelism & Performance')
    parallel_group.add_argument("-p", "--parallel-samples", type=int, default=1, 
                                help="Number of samples to process simultaneously.")
    parallel_group.add_argument("-t", "--threads-per-sample", type=int, default=8, 
                                help="Threads per sample run.")
    
    args, pass_through_flags = parser.parse_known_args()

    # Create parent output directory
    output_path = Path(args.output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    # 1. Load and validate samplesheet structure
    try:
        with open(args.samplesheet, 'r') as f:
            lines = [line.strip() for line in f if line.strip()]
            if not lines:
                raise ValueError("Samplesheet is empty.")
            max_cols = max(len(line.split(',')) for line in lines)

        col_names = ['sample'] + [f'fastq_{i}' for i in range(1, max_cols)]
        df = pd.read_csv(io.StringIO("\n".join(lines)), 
                         names=col_names, 
                         header=None, 
                         skiprows=1, 
                         engine='python')
        
        fastq_cols = [c for c in df.columns if c.startswith('fastq_')]
    except Exception as e:
        print(f"{Colors.FAIL}Error reading samplesheet: {e}{Colors.ENDC}")
        sys.exit(1)

    # 2. Pre-flight Validation: Check if files actually exist
    print(f"{Colors.BLUE}{Colors.BOLD}--- Performing Pre-flight Validation ---{Colors.ENDC}")
    missing_files = []
    valid_tasks = []

    for _, row in df.iterrows():
        sid = str(row['sample']).strip()
        fqs = [str(row[col]).strip() for col in fastq_cols if pd.notna(row[col]) and str(row[col]).strip()]
        
        if not fqs:
            print(f"{Colors.WARNING}[SKIP]{Colors.ENDC} Sample {sid} has no FASTQ files.")
            continue

        sample_missing = []
        for f in fqs:
            if not Path(f).exists():
                sample_missing.append(f)
        
        if sample_missing:
            missing_files.append((sid, sample_missing))
        else:
            valid_tasks.append((sid, fqs))

    if missing_files:
        print(f"\n{Colors.FAIL}{Colors.BOLD}FATAL ERROR: Missing FASTQ files detected!{Colors.ENDC}")
        for sid, files in missing_files:
            print(f"{Colors.WARNING}Sample: {sid}{Colors.ENDC}")
            for f in files:
                print(f"  - Missing: {f}")
        print(f"\n{Colors.FAIL}Pipeline aborted. Please fix the paths in your samplesheet.{Colors.ENDC}")
        sys.exit(1)

    print(f"{Colors.GREEN}Validation passed. All {len(valid_tasks)} samples are ready.{Colors.ENDC}\n")

    # 3. Execution via Process Pool
    print(f"{Colors.BLUE}{Colors.BOLD}--- resscan batch pipeline starting ---{Colors.ENDC}")
    print(f"{Colors.CYAN}Parallel Workers:{Colors.ENDC} {args.parallel_samples}")
    print(f"{Colors.CYAN}Threads Per Sample:{Colors.ENDC} {args.threads_per_sample}\n")

    with ProcessPoolExecutor(max_workers=args.parallel_samples) as executor:
        futures = []
        for sid, fqs in valid_tasks:
            print(f"{Colors.CYAN}[QUEUED]{Colors.ENDC} Sample: {sid} ({len(fqs)} files)")
            futures.append(executor.submit(run_single_sample, sid, fqs, args, pass_through_flags))
        
        print("") 
        for future in futures:
            print(future.result())

    duration = time.monotonic() - start_time
    print(f"\n{Colors.BLUE}{Colors.BOLD}--- All batch tasks finished in {format_duration(duration)} ---{Colors.ENDC}")

if __name__ == "__main__":
    main()